kind: Pod                                #A
apiVersion: v1
metadata:                                #B
  name: nginx
spec:                                    #C
  restartPolicy: Always
  volumes:                               #D
    - name: data
      emptyDir: {}
  initContainers:
  - name: nginx-init                     #E
    image: alpine:latest
    command: ['sh', '-c', 'echo "<html><body><h1>Hello from Kubernetes!</h1><p>This page was created by an Init Container running alpine image.</p></body></html>" > /data/index.html']
    volumeMounts:
    - name: data
      mountPath: /data
  containers:
  - name: nginx                          #F
    image: nginx:latest
    volumeMounts:
    - name: data
      mountPath: /usr/share/nginx/html
